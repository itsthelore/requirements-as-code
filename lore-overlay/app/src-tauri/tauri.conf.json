{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Lore Capture",
  "version": "0.0.0",
  "identifier": "io.github.tcballard.lore-capture",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "windows": [
      {
        "label": "capture",
        "title": "Lore Capture",
        "width": 560,
        "height": 440,
        "resizable": false,
        "visible": false,
        "alwaysOnTop": true,
        "center": true,
        "skipTaskbar": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "Productivity",
    "shortDescription": "Capture a decision from anywhere into Lore.",
    "icon": ["icons/icon.png"]
  }
}
