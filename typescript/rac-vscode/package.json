{
  "name": "rac-vscode",
  "displayName": "RAC — Requirements as Code",
  "description": "Inline validation for RAC (requirements-as-code) artifacts, powered by the rac CLI.",
  "version": "0.1.0",
  "publisher": "rac",
  "icon": "icon.png",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/itsthelore/requirements-as-code.git",
    "directory": "typescript/rac-vscode"
  },
  "bugs": {
    "url": "https://github.com/itsthelore/requirements-as-code/issues"
  },
  "keywords": [
    "rac",
    "requirements-as-code",
    "requirements",
    "decisions",
    "adr",
    "linter"
  ],
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Linters",
    "Programming Languages"
  ],
  "main": "./dist/extension.js",
  "activationEvents": [
    "workspaceContains:**/.rac/config.yaml"
  ],
  "contributes": {
    "commands": [
      {
        "command": "rac.validateWorkspace",
        "title": "RAC: Validate Open Artifacts"
      },
      {
        "command": "rac.newArtifact",
        "title": "RAC: New Artifact"
      },
      {
        "command": "rac.showExplorer",
        "title": "RAC: Open Explorer"
      }
    ],
    "configuration": {
      "title": "RAC",
      "properties": {
        "rac.path": {
          "type": "string",
          "default": "",
          "markdownDescription": "Path to the `rac` binary. Empty = the `RAC_BIN` environment variable, else `rac` on `PATH`."
        },
        "rac.validate.enable": {
          "type": "boolean",
          "default": true,
          "description": "Validate RAC artifacts and show diagnostics as you open and save them."
        }
      }
    }
  },
  "scripts": {
    "check-types": "tsc --noEmit",
    "compile": "node esbuild.mjs",
    "watch": "node esbuild.mjs --watch",
    "vscode:prepublish": "npm run check-types && npm run compile",
    "compile-tests": "tsc -p ./tsconfig.test.json",
    "pretest": "npm run compile-tests && npm run compile",
    "test": "node ./out/test/runTest.js"
  },
  "devDependencies": {
    "@rac/sdk": "file:../rac-sdk",
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.0.0",
    "@types/vscode": "^1.85.0",
    "@vscode/test-electron": "^3.0.0",
    "esbuild": "^0.25.0",
    "glob": "^13.0.6",
    "mocha": "^11.7.6",
    "typescript": "^5.8.0"
  }
}
